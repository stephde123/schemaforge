# --- LLM provider ---
# Which provider to use for deep extraction: "anthropic" | "openai" | "none"
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# --- Server ---
# Port the web UI / API listens on. Pick one that does NOT collide with your
# existing Docker project on the droplet.
PORT=8420

# --- Crawling ---
# Custom User-Agent when fetching remote URLs
FETCH_USER_AGENT=SchemaForgeBot/0.1 (+https://example.com)
# Max bytes to read from a remote page
FETCH_MAX_BYTES=3000000

# --- Storage ---
# Path to the persistent entity registry (the "memory")
REGISTRY_PATH=./data/registry.json
# Path to the schema.org vocabulary dump (run: pnpm fetch:schema)
SCHEMA_DUMP_PATH=./data/schemaorg-current-https.jsonld
